// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  stellarAddress String @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  wallets        Wallet[]
  sessions       Session[]
  signatures     Signature[]
  comments       Comment[]
  preferences    UserPreference?
  walletSettings UserWalletSettings[]
  invitations    Invitation[] @relation("ReceivedInvitations")
  sentInvites    Invitation[] @relation("SentInvitations")
  createdTasks   ScheduledTask[] @relation("CreatedTasks")
  taskTemplates  TaskTemplate[] @relation("TaskTemplates")

  @@map("users")
}

model UserPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  emailNotifications    Boolean  @default(true)
  pushNotifications     Boolean  @default(true)
  transactionAlerts     Boolean  @default(true)
  theme                 String   @default("dark") // 'light', 'dark', 'system'
  language              String   @default("en")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserWalletSettings {
  id        String   @id @default(cuid())
  userId    String
  walletId  String
  nickname  String?  // Requirement: Store "Nicknames" for wallets
  isFavorite Boolean @default(false)
  isPinned   Boolean @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([userId, walletId])
  @@map("user_wallet_settings")
}

model Invitation {
  id              String   @id @default(cuid())
  walletId        String
  inviterId       String
  inviteeAddress  String   // Stellar address being invited
  inviteeId       String?  // Linked User ID if they exist
  status          String   @default("PENDING") // 'PENDING', 'ACCEPTED', 'DECLINED', 'EXPIRED'
  role            String   @default("OWNER")
  createdAt       DateTime @default(now())
  expiresAt       DateTime?

  wallet  Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  inviter User   @relation(fields: [inviterId], references: [id], onDelete: Cascade, name: "SentInvitations")
  invitee User?  @relation(fields: [inviteeId], references: [id], onDelete: SetNull, name: "ReceivedInvitations")

  @@map("invitations")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Wallet {
  id               String   @id @default(cuid())
  name             String
  contractAddress  String   @unique
  stellarNetwork   String   // 'mainnet', 'testnet', 'futurenet'
  threshold        Int
  recoveryAddress  String
  recoveryDelay    BigInt  // in seconds
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  ownerId      String
  owner        User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  owners       WalletOwner[]
  transactions Transaction[]
  recoveries   Recovery[]

  @@map("wallets")
}

model WalletOwner {
  id       String @id @default(cuid())
  walletId String
  address  String
  addedAt  DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, address])
  @@map("wallet_owners")
}

model Transaction {
  id           String   @id @default(cuid())
  walletId     String
  transactionId BigInt  // Contract transaction ID
  destination  String
  amount       BigInt
  data         String?  // Hex string for transaction data
  executed     Boolean  @default(false)
  signatures   Int      @default(0)
  title        String?  // Off-chain metadata: Title
  description  String?  // Off-chain metadata: Description
  isDeleted    Boolean  @default(false) // Soft-delete functionality
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  executedAt   DateTime?

  // Relations
  wallet     Wallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)
  signatures_rel Signature[] @relation("TransactionSignatures")
  comments    Comment[]

  @@map("transactions")
}

model Comment {
  id            String   @id @default(cuid())
  transactionId String
  userId        String
  content       String   // Discussion/Comments
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Signature {
  id            String   @id @default(cuid())
  transactionId String
  userId        String
  signerAddress String
  signature     String?  // Hex or Base64 encoded signature fragment
  signedAt      DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade, name: "TransactionSignatures")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([transactionId, userId])
  @@map("signatures")
}

model Recovery {
  id                   String   @id @default(cuid())
  walletId             String
  newRecoveryAddress   String
  initiatedAt          DateTime @default(now())
  executeAfter         DateTime
  executed             Boolean  @default(false)
  executedAt           DateTime?
  cancelledAt          DateTime?

  // Relations
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("recoveries")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  walletId  String?
  action    String   // 'CREATE_WALLET', 'ADD_OWNER', 'REMOVE_OWNER', etc.
  details   Json?    // Additional context
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  walletId  String?
  type      String   // 'TRANSACTION_PENDING', 'RECOVERY_INITIATED', etc.
  title     String
  message   String
  data      Json?    // Additional notification data
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  name      String
  keyHash   String   // Hashed API key
  scopes    String[] // Array of permissions
  isActive  Boolean  @default(true)
  lastUsed  DateTime?
  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@map("api_keys")
}

model Webhook {
  id        String   @id @default(cuid())
  userId    String
  walletId  String?
  url       String
  secret    String   // For webhook signature verification
  events    String[] // Array of event types
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("webhooks")
}

model RateLimit {
  id        String   @id @default(cuid())
  identifier String  // IP address or user ID
  endpoint  String
  count     Int
  windowMs  BigInt   // Time window in milliseconds
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@map("rate_limits")
}

model TokenBalance {
  id          String   @id @default(cuid())
  walletId    String
  contractId  String   // Token contract address
  symbol      String   // e.g., XLM, USDC
  name        String   // Full token name
  decimals    Int
  balance     BigInt
  priceUsd    Float?   // Current USD price
  iconUrl     String?  // Token icon URL
  isVerified  Boolean  @default(false) // Whether token is verified
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, contractId])
  @@map("token_balances")
}

model TransactionHistory {
  id          String   @id @default(cuid())
  walletId    String
  txHash      String   @unique
  type        String   // 'TRANSFER_IN', 'TRANSFER_OUT', 'SWAP', etc.
  token       String   // Token symbol
  amount      BigInt
  from        String
  to          String
  timestamp   DateTime
  blockNumber BigInt?
  data        Json?    // Additional transaction data
  createdAt   DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, timestamp])
  @@index([walletId, type])
  @@map("transaction_history")
}

model Heartbeat {
  id          String   @id @default(cuid())
  walletId    String
  userId      String
  timestamp   DateTime @default(now())
  ipAddress   String?
  userAgent   String?

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, timestamp])
  @@map("heartbeats")
}

model SignerWeight {
  id         String   @id @default(cuid())
  walletId   String
  address    String
  weight     Int      @default(1)
  isActive   Boolean  @default(true)
  addedAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, address])
  @@map("signer_weights")
}

model SignerChangeProposal {
  id              String   @id @default(cuid())
  walletId        String
  proposerId      String
  proposalType    String   // 'ADD_SIGNER', 'REMOVE_SIGNER', 'CHANGE_WEIGHT'
  targetAddress   String?
  newWeight       Int?
  status          String   @default('PENDING') // 'PENDING', 'APPROVED', 'REJECTED', 'EXECUTED'
  votes           Json?    // Store vote data
  executedAt      DateTime?
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, status])
  @@map("signer_change_proposals")
}

model IndexedEvent {
  id            String   @id @default(cuid())
  contractId    String
  eventType     String
  ledger        BigInt
  transactionHash String
  timestamp     DateTime
  data          Json
  topics        String[] // Indexed topics for filtering
  
  @@index([contractId, ledger])
  @@index([contractId, eventType])
  @@index([topics])
  @@map("indexed_events")
}

model EventIndexerState {
  id              String   @id @default(cuid())
  network         String   @unique // e.g., 'futurenet', 'mainnet'
  lastLedger      BigInt
  lastSync        DateTime @default(now())
  isHealthy       Boolean  @default(true)
  
  @@map("event_indexer_state")
}

// Task Management System Models
model ScheduledTask {
  id              String   @id @default(cuid())
  name            String
  description     String?
  taskType        String   // 'WEEKLY_SUMMARY', 'MONTHLY_AUDIT', 'FILE_CLEANUP', 'CUSTOM', etc.
  cronExpression  String
  timezone        String   @default("UTC")
  isActive        Boolean  @default(true)
  priority        Int      @default(5) // 1-10, lower number = higher priority
  maxRetries      Int      @default(3)
  timeoutMs       Int      @default(300000) // 5 minutes default
  createdBy       String?  // User ID who created this task
  metadata        Json?    // Additional task configuration
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  runCount        Int      @default(0)
  successCount    Int      @default(0)
  failureCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  executions      TaskExecution[]
  creator         User?    @relation("CreatedTasks", fields: [createdBy], references: [id], onDelete: SetNull)
  
  @@map("scheduled_tasks")
}

model TaskExecution {
  id              String   @id @default(cuid())
  taskId          String
  jobId           String?  // Bull queue job ID
  status          String   @default("PENDING") // 'PENDING', 'RUNNING', 'COMPLETED', 'FAILED', 'CANCELLED', 'TIMEOUT'
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      BigInt?  // Execution duration in milliseconds
  result          Json?    // Task execution result
  errorMessage    String?
  errorStack      String?
  retryCount      Int      @default(0)
  workerId        String?  // ID of the worker that processed this task
  nodeId          String?  // ID of the node that processed this task (for distributed execution)
  metadata        Json?    // Execution metadata
  
  // Relations
  task            ScheduledTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  logs            TaskLog[]
  
  @@index([taskId, status])
  @@index([status, startedAt])
  @@index([workerId])
  @@index([nodeId])
  @@map("task_executions")
}

model TaskLog {
  id              String   @id @default(cuid())
  executionId     String
  level           String   // 'DEBUG', 'INFO', 'WARN', 'ERROR'
  message         String
  timestamp       DateTime @default(now())
  metadata        Json?
  
  // Relations
  execution       TaskExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  @@index([executionId, timestamp])
  @@index([level, timestamp])
  @@map("task_logs")
}

model WorkerNode {
  id              String   @id @default(cuid())
  nodeId          String   @unique // Unique identifier for this worker node
  hostname        String
  ipAddress       String?
  version         String?  // Application version
  status          String   @default("ONLINE") // 'ONLINE', 'OFFLINE', 'MAINTENANCE'
  capabilities    Json?    // Worker capabilities and configuration
  lastHeartbeat   DateTime @default(now())
  currentLoad     Int      @default(0) // Number of currently running tasks
  maxConcurrency  Int      @default(10) // Maximum concurrent tasks
  totalProcessed  BigInt   @default(0) // Total tasks processed
  totalFailed     BigInt   @default(0) // Total tasks failed
  metadata        Json?    // Additional node metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([status, lastHeartbeat])
  @@index([nodeId])
  @@map("worker_nodes")
}

model TaskDependency {
  id              String   @id @default(cuid())
  taskId          String
  dependsOnTaskId String
  dependencyType  String   @default("SUCCESS") // 'SUCCESS', 'COMPLETION', 'FAILURE'
  
  task            ScheduledTask @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask   ScheduledTask @relation("DependentTasks", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)
  
  @@unique([taskId, dependsOnTaskId])
  @@map("task_dependencies")
}

model TaskTemplate {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  taskType        String
  defaultCron     String?
  defaultTimeout  Int      @default(300000)
  defaultRetries  Int      @default(3)
  configuration   Json     // Template configuration schema
  isActive        Boolean  @default(true)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  creator         User?    @relation("TaskTemplates", fields: [createdBy], references: [id], onDelete: SetNull)
  
  @@map("task_templates")
}

